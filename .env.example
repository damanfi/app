VITE_RPC_URL=https://rpc.testnet.arc.network
VITE_CHAIN_ID=5042002

# Proxy addresses (UUPS pattern). Live on Arc testnet as of
# 2026-05-24; mirror damanfi/copy-bond/.deployments/arc-testnet.json.
# Override per environment (anvil fork, future mainnet deploy).
VITE_COPY_BOND_ADDRESS=0x493085c71f3CaceB8373db6e6ffeF43EacbC3e02
VITE_REPUTATION_REGISTRY=0xAA1a021215322FbB775c6Cc08d81347864a7Ac94
VITE_BOUNTY_ACCRUAL=0xF0Dc40875f56D0703B4C9e3823ACa5d9d9E73F16
VITE_BOND_YIELD_VAULT=0xe98b4695753D03B644c063C0bb3A3bdd01Cc50dD
VITE_UNIVERSE_REGISTRY=0xfea80c061a9ed8a25b33e0b6b9f1490bdb10d270
VITE_TIMELOCK_ADDRESS=0xa22510860289751C092e67B15b827020CE09DAbf
VITE_SAFE_ADDRESS=0x70a34ca4964a16a934432871a593acba5dd63cf1
VITE_HUMD_REGISTRY=0x02CAf55d8a8c43453268764e84cb297CfB347749

# Substrate (reverbprotocol) proxies referenced by the receipts view.
VITE_REFUND_PROTOCOL=0xc8bF99c55703bc682a3Efd5c8A728EaEda3E121F
VITE_OPERATOR=0x344b472b7b1ad0a35e11718bc063fd46f4282db2

# Optional: pull addresses from the deployments file at runtime.
# When set, the storefront fetches this URL on boot and uses the
# returned proxy addresses; env values above are fallbacks.
VITE_DEPLOYMENTS_URL=

# Arc testnet pre-deploys (USDC is the native gas token, 18 decimals).
VITE_USDC_ADDRESS=0x3600000000000000000000000000000000000000
VITE_EURC_ADDRESS=0x89B50855Aa3bE2F677cD6303Cec089B5F319D72a
VITE_GATEWAY_MINTER=0x0022222ABE238Cc2C7Bb1f21003F0a260052475B
VITE_GATEWAY_WALLET=0x0077777d7EBA4688BDeF3E311b846F25870A19B9

# Circle Paymaster (ERC-4337 + EIP-2612 permit + Pimlico bundler).
# When unset, the app falls back to the non-gasless onboarding path.
VITE_PIMLICO_BUNDLER_URL=
VITE_CIRCLE_PAYMASTER_ADDRESS=

# Gateway Balance API (permissionless, no key required).
VITE_GATEWAY_BALANCE_API=https://gateway-api-testnet.circle.com/v1/balances
