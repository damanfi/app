VITE_RPC_URL=https://rpc.testnet.arc.network
VITE_CHAIN_ID=5042002

# Proxy addresses (UUPS pattern). The storefront reads these from
# damanfi/copy-bond/.deployments/arc-testnet.json once the deploy
# script lands. Until then, the env values stand in. Both routes
# resolve to the same proxy address; the storefront prefers the
# env when set so local development can target an anvil fork.
VITE_COPY_BOND_ADDRESS=0x0000000000000000000000000000000000000000
VITE_REPUTATION_REGISTRY=0x0000000000000000000000000000000000000000
VITE_BOUNTY_ACCRUAL=0x0000000000000000000000000000000000000000
VITE_TIMELOCK_ADDRESS=0x0000000000000000000000000000000000000000

# Optional: pull addresses from the deployments file at runtime.
# When set, the storefront fetches this URL on boot and uses the
# returned proxy addresses; env values above are fallbacks.
VITE_DEPLOYMENTS_URL=

# Arc testnet pre-deploys (USDC is the native gas token, 18 decimals).
VITE_USDC_ADDRESS=0x3600000000000000000000000000000000000000
VITE_EURC_ADDRESS=0x89B50855Aa3bE2F677cD6303Cec089B5F319D72a
VITE_GATEWAY_MINTER=0x0022222ABE238Cc2C7Bb1f21003F0a260052475B
VITE_GATEWAY_WALLET=0x0077777d7EBA4688BDeF3E311b846F25870A19B9

# Circle Paymaster (ERC-4337 + EIP-2612 permit + Pimlico bundler).
# When unset, the app falls back to the non-gasless onboarding path.
VITE_PIMLICO_BUNDLER_URL=
VITE_CIRCLE_PAYMASTER_ADDRESS=

# Gateway Balance API (permissionless, no key required).
VITE_GATEWAY_BALANCE_API=https://gateway-api-testnet.circle.com/v1/balances
